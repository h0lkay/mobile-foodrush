<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp"
    android:clickable="true"
    android:focusable="true">

    <RadioButton
        android:id="@+id/addressRadioButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:buttonTint="#2196F3"
        android:clickable="false"
        android:focusable="false" />

    <TextView
        android:id="@+id/addressText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:layout_toEndOf="@id/addressRadioButton"
        android:layout_toStartOf="@id/btnDeleteAddress"
        android:fontFamily="serif"
        android:text="Красноярск, ул. Борисова, д. 3"
        android:textColor="#000000"
        android:textSize="18sp" />

    <ImageView
        android:id="@+id/btnDeleteAddress"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="5dp"
        android:padding="6dp"
        android:src="@android:drawable/ic_menu_delete"
        android:alpha="0.6"
        android:contentDescription="Удалить адрес" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="10dp"
        android:background="#EAEAEA" />

</RelativeLayout>
