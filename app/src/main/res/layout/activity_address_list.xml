<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0F5">

    <!-- Карта на заднем плане -->
    <ImageView
        android:id="@+id/fullMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/map"
        android:contentDescription="@null" />

    <!-- Кнопка закрытия -->
    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/circle_white"
        android:padding="10dp"
        android:src="@drawable/close"
        app:tint="#000000"
        android:elevation="4dp"
        android:contentDescription="@null" />

    <!-- Белая шторка с адресами -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/card_background_rounded_large_bordered"
        android:paddingTop="12dp"
        android:elevation="10dp">

        <View
            android:id="@+id/handle"
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:layout_centerHorizontal="true"
            android:background="#D9D9D9" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/handle"
            android:layout_marginStart="25dp"
            android:layout_marginTop="20dp"
            android:fontFamily="serif"
            android:text="Мои адреса"
            android:textColor="#000000"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNewAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/title"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="25dp"
            android:background="@drawable/background_rounded"
            android:backgroundTint="#D9D9D9"
            android:paddingHorizontal="15dp"
            android:paddingVertical="8dp"
            android:text="+ Новый адрес"
            android:textColor="#000000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>

        <ScrollView
            android:id="@+id/addressScroll"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_below="@id/title"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="25dp">

            <LinearLayout
                android:id="@+id/addressContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/btnDeliverHere"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_below="@id/addressScroll"
            android:layout_marginHorizontal="25dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/button_red_bg"
            android:fontFamily="serif"
            android:text="Доставить сюда"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </RelativeLayout>

</RelativeLayout>
