<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Разрешения для работы карты -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" tools:node="replace" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KolobanovDA_KI23161b_PR2"
        android:networkSecurityConfig="@xml/network_security_config">
        
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
        
        <activity
            android:name=".RestaurantActivity"
            android:exported="false"
            android:label="@string/restaurant_details"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
        
        <activity
            android:name=".FoodActivity"
            android:exported="false"
            android:label="Food Details"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
        
        <activity
            android:name=".AddressActivity"
            android:exported="false"
            android:label="@string/delivery_address"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />

        <activity
            android:name=".AddressListActivity"
            android:exported="false"
            android:label="Мои адреса"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
        
        <activity
            android:name=".CartActivity"
            android:exported="false"
            android:label="@string/cart"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
        
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:label="Profile"
            android:theme="@style/Theme.KolobanovDA_KI23161b_PR2" />
    </application>

</manifest>
